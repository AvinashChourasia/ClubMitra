# Copy this file to `.env` and adjust as needed.
# `.env` is gitignored (it holds secrets); `.env.example` is committed as a template.

# --- Database ---
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=disable
# These credentials match docker-compose.yml. Host port is 5433 (see compose
# comment). sslmode=disable is fine for local Docker.
DATABASE_URL=postgres://clubmitra:clubmitra@localhost:5433/clubmitra?sslmode=disable

# --- Redis (challenge leaderboards) ---
# Host port 6380 (see compose comment). Format: redis://[:password@]host:port[/db]
REDIS_URL=redis://localhost:6380

# --- Auth ---
# ClubMitra is standalone: it owns identity and stores bcrypt password hashes, so
# register/login are handled in-app (no external identity provider).
# Generate strong values with:  openssl rand -base64 32
JWT_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me

# --- Server ---
# 8080 is a very common default (Tomcat, etc.); 8090 avoids local conflicts.
PORT=8090
ENV=development
